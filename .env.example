# Production must use a real random secret with at least 32 characters.
BETTER_AUTH_SECRET=generate-a-long-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000/api/auth
APP_URL=http://localhost:3000

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM_NAME=UAB Thesis Portal
